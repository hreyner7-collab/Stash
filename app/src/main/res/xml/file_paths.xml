<?xml version="1.0" encoding="utf-8"?>
<!--
    FileProvider path configuration. Only the crashes subdirectory of
    cacheDir is exposed — the share Intent in Settings hands out a
    content:// URI scoped to a single crash report. No other paths are
    reachable through this provider.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <cache-path name="crashes" path="crashes/" />
</paths>
